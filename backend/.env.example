# Plantilla de .env para backend

# ===== SERVIDOR =====
PORT=3000
NODE_ENV=development

# ===== BASE DE DATOS =====
# Opción 1: MongoDB local
MONGODB_URI=mongodb://localhost:27017/socialerp

# Opción 2: MongoDB Atlas (descomenta y actualiza)
# MONGODB_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/socialerp?retryWrites=true&w=majority

# ===== API EXTERNO =====
# URL por defecto si no se proporciona config
API_DEFAULT_URL=https://fc.socialerp.net:8050

# Mapa de configuraciones por cliente (formato JSON)
# Sintaxis: {"nombreCliente":"https://url.api","otro":"https://otro.api"}
# Acceso desde frontend: /?config=nombreCliente
API_CONFIG_MAP={"default":"https://fc.socialerp.net:8443","cliente1":"https://api.cliente1.com","cliente2":"https://api.cliente2.com"}

# ===== AUTENTICACIÓN SUPERUSUARIO =====
SUPERUSER_USERNAME=admin
SUPERUSER_PASSWORD=admin123

# CAMBIAR ESTOS VALORES EN PRODUCCIÓN
JWT_SECRET=your-super-secret-key-change-in-production-12345

# ===== CORS =====
# URL del frontend que puede acceder al backend
CORS_ORIGIN=http://localhost:3001

# ===== LOGGING (opcional) =====
# Nivel de log: debug, info, warn, error
LOG_LEVEL=info
